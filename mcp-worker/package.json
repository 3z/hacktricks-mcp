{
  "name": "hacktricks-mcp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:sql": "node scripts/build-sql.mjs",
    "db:schema:local": "wrangler d1 execute hacktricks --file=schema.sql --local",
    "db:data:local": "wrangler d1 execute hacktricks --file=data.sql --local",
    "db:schema": "wrangler d1 execute hacktricks --file=schema.sql --remote",
    "db:data": "wrangler d1 import hacktricks --file=data.sql --remote",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "^4.103.0"
  }
}
